# Banco PostgreSQL
# Exemplo local:
# EXPERIMENTS_CONNECTION_STRING=Host=host.docker.internal;Port=5432;Database=postgres;Username=postgres;Password=postgres
#
# Exemplo Railway:
# EXPERIMENTS_CONNECTION_STRING=Host=hopper.proxy.rlwy.net;Port=45947;Database=railway;Username=postgres;Password=SUA_SENHA;SSL Mode=Require;Trust Server Certificate=true
EXPERIMENTS_CONNECTION_STRING=Host=host.docker.internal;Port=5432;Database=postgres;Username=postgres;Password=postgres

# Portas expostas no host
FRONTEND_PORT=3000
BACKEND_PORT=5080

# URLs internas do container
INTERNAL_API_BASE_URL=http://127.0.0.1:5080/api
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5080/api
