# Google Service Account JSON content as a single line string
# You can get this from the Google Cloud Console (IAM & Admin > Service Accounts)
GOOGLE_SERVICE_ACCOUNT_INFO='{"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", "client_email": "...", "client_id": "...", "auth_uri": "...", "token_uri": "...", "auth_provider_x509_cert_url": "...", "client_x509_cert_url": "..."}'

# id do calendário padrão a ser usado pelas tools (ex: calendar resource id)
GOOGLE_CALENDAR_ID=your_calendar_id_here

# Fuso horário padrão a ser usado nas ferramentas (ex: America/Sao_Paulo)
TIMEZONE=America/Sao_Paulo