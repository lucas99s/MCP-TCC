# PostgreSQL MCP Server - Environment Variables Configuration

## Required Environment Variables

# PostgreSQL database name
POSTGRES_DATABASE=your_database_name

# PostgreSQL username
POSTGRES_USERNAME=your_username

# PostgreSQL password
POSTGRES_PASSWORD=your_password

## Optional Environment Variables

# PostgreSQL host (default: localhost)
# Se o banco estiver na máquina host use: host.docker.internal (Windows/macOS) ou IP da máquina (Linux)
POSTGRES_HOST=localhost

# PostgreSQL port (default: 5432)
POSTGRES_PORT=5432

# Connection timeout in seconds (default: 30)
POSTGRES_TIMEOUT=30

# Maximum connection pool size (default: 100)
POSTGRES_MAX_POOL_SIZE=100

## Exemplos de configuraçăo:

# Banco PostgreSQL local na máquina host (Windows/macOS):
# POSTGRES_HOST=host.docker.internal
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=mydb
# POSTGRES_USERNAME=postgres
# POSTGRES_PASSWORD=mypassword

# Banco PostgreSQL local na máquina host (Linux):
# POSTGRES_HOST=172.17.0.1  # ou o IP da sua máquina
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=mydb
# POSTGRES_USERNAME=postgres
# POSTGRES_PASSWORD=mypassword

# Banco PostgreSQL remoto:
# POSTGRES_HOST=my-db-server.example.com
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=production_db
# POSTGRES_USERNAME=app_user
# POSTGRES_PASSWORD=secure_password
